# ── Auth.js / NextAuth v5 ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Full URL of this server — required in production / behind a reverse proxy.
# In Docker Compose it should match what NEXTAUTH_URL was in v4.
AUTH_URL=http://localhost:3000

# ── Azure Entra ID (formerly Azure AD) ──────────────────────────────────────
# 1. Go to Azure Portal → App registrations → New registration
# 2. Set redirect URI:
#      http://localhost:3000/api/auth/callback/microsoft-entra-id  (dev)
#      https://<your-domain>/api/auth/callback/microsoft-entra-id  (prod)
# 3. Under Certificates & secrets → New client secret
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# Leave blank for multi-tenant; set for single-tenant (recommended).
AZURE_AD_TENANT_ID=

# ── Database ─────────────────────────────────────────────────────────────────
# Shares the same PostgreSQL instance as the pipeline container.
# In Docker Compose, "db" resolves to the postgres service.
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pii_audit

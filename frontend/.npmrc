# Supply-chain hardening: do not run package lifecycle scripts on install.
# The 2026 npm compromises (axios, node-ipc, @redhat-cloud-services, the
# typosquat/dependency-confusion waves) all delivered credential-stealing
# payloads via preinstall/postinstall hooks. Disabling scripts neutralizes
# that vector. If a dependency ever genuinely needs a build step, run it
# explicitly and intentionally rather than re-enabling this globally.
ignore-scripts=true

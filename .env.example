# -----------------------------------------------------------------------
# Azure Service Principal credentials
# Required when running outside Azure-managed compute (e.g. local Docker).
# DefaultAzureCredential picks these up automatically when they are set.
# -----------------------------------------------------------------------
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# -----------------------------------------------------------------------
# Source Delta table (read)
# Format: abfss://<workspace>@onelake.dfs.fabric.microsoft.com/<lakehouse>.Lakehouse/Tables/<table>
# -----------------------------------------------------------------------
SOURCE_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/SourceLakehouse.Lakehouse/Tables/raw_customers

# -----------------------------------------------------------------------
# Target Delta table (write — anonymized output)
# The target Lakehouse must be in the same or a different workspace.
# The table will be created if it does not yet exist.
# -----------------------------------------------------------------------
TARGET_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/TargetLakehouse.Lakehouse/Tables/anonymized_customers

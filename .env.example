# Azure Service Principal credentials
# Required outside Azure-managed compute. DefaultAzureCredential reads these.
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# PostgreSQL audit database (run status, column events, alerts).
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pii_audit

# Dynamic 1-to-1 table discovery — recommended for production.
# Lists every Delta table directory under SOURCE_BASE_ABFSS_URI and writes an
# anonymized copy to the same name under TARGET_BASE_ABFSS_URI automatically.
SOURCE_BASE_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/SourceLakehouse.Lakehouse/Tables/raw
TARGET_BASE_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/TargetLakehouse.Lakehouse/Files/anonymized

# Single-table fallback for smoke tests (used only when dynamic discovery finds nothing).
# SOURCE_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/SourceLakehouse.Lakehouse/Tables/raw_customers
# TARGET_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/TargetLakehouse.Lakehouse/Files/anonymized/customers.parquet

# Microsoft Purview sensitivity-label cross-check.
PURVIEW_ACCOUNT_NAME=my-purview-account

# k-anonymity enforcement.
K_ANONYMITY_MIN=5

# Optional explicit overrides. Leave blank to use data-driven classification.
QUASI_IDENTIFIER_COLS=
IDENTIFIER_COLS=

# Secret salt mixed into SHA-256 hashes of identifier columns.
# Use the same salt across runs to preserve joins.
HASH_SALT=your-long-random-secret-salt

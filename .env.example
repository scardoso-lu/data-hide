# ─────────────────────────────────────────────────────────────────────────────
# Azure Service Principal credentials
# Required when running outside Azure-managed compute (e.g. local Docker).
# DefaultAzureCredential picks these up automatically when set.
# On ACI / AKS / Azure ML with a Managed Identity, omit all three.
# ─────────────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# ─────────────────────────────────────────────────────────────────────────────
# Source Delta table  (read)
# Format: abfss://<Workspace>@onelake.dfs.fabric.microsoft.com/<Lakehouse>.Lakehouse/Tables/<Table>
# ─────────────────────────────────────────────────────────────────────────────
SOURCE_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/SourceLakehouse.Lakehouse/Tables/raw_customers

# ─────────────────────────────────────────────────────────────────────────────
# Target Delta table  (write — anonymized output)
# Can be in a different Workspace / Lakehouse. Created automatically if absent.
# ─────────────────────────────────────────────────────────────────────────────
TARGET_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/TargetLakehouse.Lakehouse/Tables/anonymized_customers

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL audit database  (optional but strongly recommended)
# Standard DSN format: postgresql://user:password@host:port/dbname
# Tables are created automatically on first run.
# When running locally with docker-compose this is set by the compose file.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pii_audit

# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Purview  (optional — sensitivity-label cross-check)
# Set to the Purview account name (not the full URL) to enable.
# The service principal must have the "Data Reader" role on the Purview account.
# Leave blank to skip Purview validation.
# ─────────────────────────────────────────────────────────────────────────────
PURVIEW_ACCOUNT_NAME=my-purview-account

# ─────────────────────────────────────────────────────────────────────────────
# Alert webhook  (optional — Teams / Slack / generic)
# Receives a JSON {"text": "..."} POST on any pipeline failure.
# Teams:  paste the URL from the Teams channel connector wizard
# Slack:  paste the URL from the Slack Incoming Webhooks app
# Leave blank to suppress alerts.
# ─────────────────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR_TEAMS_WEBHOOK_URL

# ─────────────────────────────────────────────────────────────────────────────
# k-Anonymity enforcement  (optional)
# Minimum group size for quasi-identifier combinations.
# Rows in groups smaller than K_ANONYMITY_MIN are suppressed before writing.
# Default: 5
# ─────────────────────────────────────────────────────────────────────────────
K_ANONYMITY_MIN=5

# ─────────────────────────────────────────────────────────────────────────────
# Quasi-identifier columns  (optional)
# Comma-separated list of column names to treat as quasi-identifiers for
# k-anonymity enforcement (e.g. age, gender, zip_code, city).
# When omitted the pipeline auto-detects columns by keyword matching.
# ─────────────────────────────────────────────────────────────────────────────
QUASI_IDENTIFIER_COLS=age,gender,zip_code,city

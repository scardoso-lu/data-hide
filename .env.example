# =============================================================================
# .env — secrets and connectivity only
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# Runtime behaviour (k-anonymity, GPS precision, column exclusions, etc.) is
# managed entirely through PostgreSQL — see the two tables below.
# Run `python test_onelake.py` to verify connectivity and inspect loaded config.
#
# ── PostgreSQL tables for runtime configuration ───────────────────────────────
#
# pii_pipeline_config          key / value overrides for tunable parameters:
#
#   K_ANONYMITY_MIN            minimum group size (default 5)
#   K_ANONYMITY_TABLES         comma-separated table names where k-anonymity runs
#   GPS_PRECISION              decimal places for GPS rounding (default 1)
#   ENABLE_KEY_VAULT           1 (default) or 0 to use local HMAC hash
#   IDENTIFIER_COLS            extra columns to always hash (comma-separated)
#   PURVIEW_ACCOUNT_NAME       Microsoft Purview account name
#   SQL_ENDPOINT_URL           Fabric SQL Analytics Endpoint URL
#   SQL_DATABASE               database name on the SQL endpoint
#   MAX_TABLE_WORKERS          parallel table workers (default 1)
#   QUASI_IDENTIFIER_COLS__<table>   quasi-identifier columns per table
#
# pii_column_exclusions        columns to skip anonymization entirely:
#
#   INSERT INTO pii_column_exclusions (table_name, column_name, reason)
#   VALUES ('my_table', 'DIENSTART_KURZNAME', 'duty-type label, not a person name');
#
# =============================================================================


# ── Azure identity ─────────────────────────────────────────────────────────────
# Service principal used for OneLake (ADLS), Fabric REST API, and SQL endpoint.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=


# ── PostgreSQL audit database ──────────────────────────────────────────────────
# Used for run records, alerts, runtime config, and column exclusions.
#
# Option A — individual variables (recommended for Azure Container Apps).
# Passwords with special characters (@ # % etc.) are passed verbatim; no
# URL-encoding is required. DB_HOST takes priority over DATABASE_URL.
DB_HOST=localhost
DB_PORT=5432
DB_USER=pipeline
DB_PASSWORD=pipeline
DB_NAME=pii_audit
#
# Option B — single connection URL (convenient for local / Docker Compose runs
# where the password contains no special characters).
# DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pii_audit


# ── OneLake paths ─────────────────────────────────────────────────────────────
# SOURCE must point to a Lakehouse Tables root (read-only).
# TARGET must end with <lakehouse>.Lakehouse/Tables (write).
SOURCE_BASE_ABFSS_URI=abfss://<workspace>@onelake.dfs.fabric.microsoft.com/<lakehouse>.Lakehouse/Tables
TARGET_BASE_ABFSS_URI=abfss://<workspace>@onelake.dfs.fabric.microsoft.com/<lakehouse>.Lakehouse/Tables


# ── Key Vault pseudonymization ────────────────────────────────────────────────
# Required when ENABLE_KEY_VAULT=1 (the default) and identifier columns exist.
# Set ENABLE_KEY_VAULT=0 in pii_pipeline_config to use local HMAC-SHA256 instead.
KEY_VAULT_URL=https://<vault-name>.vault.azure.net/
KEY_VAULT_RSA_KEY_NAME=<key-name>

# Secret salt for local HMAC hash (only used when ENABLE_KEY_VAULT=0).
# If omitted a fixed default is used — deterministic but not secret,
# so only suitable for development.
HASH_SALT=

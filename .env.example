# Azure Service Principal credentials
# Required outside Azure-managed compute. DefaultAzureCredential reads these.
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# PostgreSQL audit database (run status, column events, alerts).
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pii_audit

# Dynamic 1-to-1 table discovery.
# Point SOURCE_BASE_ABFSS_URI at the Lakehouse root; the pipeline discovers
# every Delta table under <lakehouse>/Tables automatically.
SOURCE_BASE_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/SourceLakehouse.Lakehouse
TARGET_BASE_ABFSS_URI=abfss://MyWorkspace@onelake.dfs.fabric.microsoft.com/TargetLakehouse.Lakehouse/Files/anonymized

# Microsoft Purview sensitivity-label cross-check.
PURVIEW_ACCOUNT_NAME=my-purview-account

# k-anonymity enforcement.
K_ANONYMITY_MIN=5

# Optional explicit overrides. Leave blank to use data-driven classification.
QUASI_IDENTIFIER_COLS=
IDENTIFIER_COLS=

# Azure Key Vault — RSA-bound pseudonymization of identifier columns.
# The pipeline signs a fixed constant with the configured RSA key inside
# Key Vault to derive a per-run HMAC secret; identifiers are then HMAC'd
# locally to 24-hex-character tokens.  The private key never leaves the HSM.
# The latest enabled version of the key is always used — rotating the key
# rotates every pseudonym produced after the rotation.
KEY_VAULT_URL=https://my-vault.vault.azure.net/
KEY_VAULT_RSA_KEY_NAME=pii-pipeline-pseudonym-key

# Fabric SQL Analytics Endpoint (optional).
# When set, shortcuts and views not reachable via ADLS Delta discovery are read
# directly via T-SQL using AAD token auth (ODBC Driver 18 for SQL Server).
# SQL_ENDPOINT_URL is the hostname shown in Fabric portal → SQL endpoint → Connection string.
SQL_ENDPOINT_URL=myworkspace.datawarehouse.fabric.microsoft.com
SQL_DATABASE=SourceLakehouse

# Directory where spaCy models are downloaded on first startup and cached for
# subsequent runs. Mount a volume here to avoid re-downloading across restarts.
SPACY_MODELS_DIR=/app/models

# GPS spatial rounding precision (decimal places of latitude/longitude).
#   1 → ~11 km cells  (default — city-safe; finer cells are near-unique
#                      per person once combined with day-level timestamps)
#   2 → ~1.1 km cells (use only for sparse, non-trajectory datasets)
#   3 → ~110 m cells  (high re-identification risk; rarely appropriate)
GPS_PRECISION=1

# =============================================================================
# .env — secrets and connectivity only
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.


# ── Azure identity ─────────────────────────────────────────────────────────────
# Service principal used for OneLake (ADLS), Fabric REST API, and SQL endpoint.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=


# ── PostgreSQL audit database ──────────────────────────────────────────────────
# Used for run records, alerts, runtime config, and column exclusions.
#
# Option A — individual variables (recommended for Azure Container Apps).
# Passwords with special characters (@ # % etc.) are passed verbatim; no
# URL-encoding is required.
DB_HOST=localhost
DB_PORT=5432
DB_USER=pipeline
DB_PASSWORD=pipeline
DB_NAME=pii_audit



# ── Key Vault pseudonymization ────────────────────────────────────────────────
# Required when ENABLE_KEY_VAULT=1 (the default) and identifier columns exist.
# Set ENABLE_KEY_VAULT=0 in pii_pipeline_config to use local HMAC-SHA256 instead.
KEY_VAULT_URL=https://<vault-name>.vault.azure.net/
KEY_VAULT_RSA_KEY_NAME=<key-name>

# Secret salt for local HMAC hash (only used when ENABLE_KEY_VAULT=0).
# If omitted a fixed default is used — deterministic but not secret,
# so only suitable for development.
HASH_SALT=
